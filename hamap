_MAP_BG     = '#0d1b2a'    # deep navy — ocean / figure background
_LAND_COLOR = '#1e3a1e'    # dark green land
_COAST_CLR  = '#3a7a3a'    # coastline / border colour
_GRID_CLR   = '#1e3050'    # graticule colour

